{
  "version": 2,
  "builds": [
    {
      "src": "front/package.json",
      "use": "@vercel/angular",
      "config": {
        "outputDirectory": "dist/Adan-Barbosa-musico/browser"
      }
    },
    {
      "src": "back/api/*.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "back/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "front/$1"
    }
  ]
}
